# HTTP server (volání z PHP / LAN; na Pi drž HOST=127.0.0.1 dokud nemáš firewall/Tailscale jasně)
HOST=127.0.0.1
PORT=3780

# Ladění: viditelný Chromium (HEADLESS=false NEBO PLAYWRIGHT_HEADED=1)
# HEADLESS=true
# PLAYWRIGHT_HEADED=0
# Volitelně zpomalení akcí v ms (jen při ladění)
# PLAYWRIGHT_SLOW_MO=150

# Pokud je nastavené, POST /run vyžaduje hlavičku: X-Worker-Secret: <hodnota>
# WORKER_SECRET=

# Vstup Seller portálu (stejné jako dřív u PHP)
PORTAL_ENTRY_URL=https://sellerportal.kaufland.de

# Dashboard KPI: základ URL bez query + seznam storefrontů (GET ?storefront= — ne roletka)
# COCKPIT_DASHBOARD_BASE=https://sellerportal.kaufland.de/dashboard
# COCKPIT_STOREFRONTS=de,cz,sk,at,pl,fr,it
# Zpětná kompatibilita: jen COCKPIT_DASHBOARD_URL=https://.../dashboard?storefront=de → bere se pathname jako BASE

# Uložená relace Playwright (cookies + storage). Výchozí: pi-worker/var/storage-state.json
# PLAYWRIGHT_STORAGE_STATE=

# Přihlášení (job loginEmailPassword – hodnoty jen v reálném .env)
# KAUFLAND_SELLER_EMAIL=
# KAUFLAND_SELLER_PASSWORD=
# TOTP_SECRET=   # Base32 z „zadat ručně“ (mezeru smaž); job loginWithTotp

# --- Laravel řízení scrapu (volitelné; bez SCRAPE_API_BASE + hashe se worker chová jen podle .env) ---
#
# GET nastavení: SCRAPE_API_BASE + /kaufland/scrape-settings (JSON kaufland_kpi_scrape_*).
# POST výsledků: SCRAPE_API_BASE + /kaufland/scrape-ingest
# SCRAPE_API_BASE=https://api.example.com
#
# Volitelně plné URL (jiný host než base):
# SCRAPE_SETTINGS_URL=
# SCRAPE_INGEST_URL=
#
# Tajemství do hlaviček (openssl rand -hex 32):
# SCRAPE_CONTROL_HASH=   # GET settings (fixní hlavička X-Kaufland-Scrape-Ingest-Secret)
# SCRAPE_INGEST_HASH=
# SCRAPE_FETCH_TIMEOUT_MS=30000

# Logy: pi-worker/var/logs/run-YYYY-MM-DD.log a error-YYYY-MM-DD.log; mazání podle stáří názvu
# LOG_RUN_RETENTION_DAYS=7
# LOG_ERROR_RETENTION_DAYS=30
# LOG_PRUNE_INTERVAL_MS=3600000
